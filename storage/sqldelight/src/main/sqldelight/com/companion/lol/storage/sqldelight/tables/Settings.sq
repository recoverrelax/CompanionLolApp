import com.companion.lol.storage.impl.model.ids.SingleId;
import com.companion.lol.storage.impl.model.other.GridSize;
import com.companion.lol.storage.impl.model.other.SortOrder;

CREATE TABLE SettingsTable (
  id INTEGER AS SingleId NOT NULL PRIMARY KEY CHECK(id = 1),
  championGridSize TEXT AS GridSize NOT NULL,
  championSortOrder TEXT AS SortOrder NOT NULL
);

insert:
INSERT OR REPLACE INTO SettingsTable VALUES ?;

findAll:
SELECT * FROM SettingsTable;